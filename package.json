{
  "name": "moonsale-bot",
  "version": "1.0.0",
  "description": "MoonSale 24/7 Telegram support bot — smart search, no AI cost",
  "main": "bot.js",
  "type": "module",
  "scripts": {
    "scrape": "node scraper.js",
    "build":  "node buildKnowledgeBase.js",
    "search": "node searchEngine.js",
    "test":   "node tests.js",
    "test:searchEngine": "node searchEngine.regression.js",
    "test:conversation": "node conversationStressTest.js",
    "bot":    "node bot.js",
    "bot:api": "node pollingApiBot.js",
    "setup":  "node scraper.js && node buildKnowledgeBase.js",
    "webhook:set": "node setWebhook.js",
    "webhook:info": "node getWebhookInfo.js"
  },
  "dependencies": {
    "puppeteer":   "^22.0.0",
    "node-telegram-bot-api": "^0.66.0"
  }
}
